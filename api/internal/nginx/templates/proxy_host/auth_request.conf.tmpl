{{- /* ForwardAuth partials (#179). Invoked from base/waf/cache server blocks.
       Exactly one auth_request per location — guaranteed mutually exclusive with
       the geo-challenge auth_request by service-layer validation. */ -}}
{{- define "_auth_verify_location" -}}
    # --- ForwardAuth ({{.AuthProvider.Type}}) verify endpoint ---
{{- if or (eq .AuthProvider.Type "authentik") .AuthProvider.Config.LargeBuffers}}
    proxy_buffers 8 16k;
    proxy_buffer_size 32k;
{{- end}}
{{- if eq .AuthProvider.Type "authelia"}}
    location = /internal/forwardauth/verify {
        internal;
        proxy_pass {{.AuthProvider.ProviderURL}}/api/authz/auth-request;
        proxy_set_header X-Original-Method $request_method;
        proxy_set_header X-Original-URL $scheme://$host$request_uri;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header Content-Length "";
        proxy_pass_request_body off;
        proxy_connect_timeout 5s;
        proxy_read_timeout {{.AuthProvider.TimeoutMs}}ms;
        modsecurity off;
    }
{{- else if eq .AuthProvider.Type "authentik"}}
    # Public outpost location (NOT auth-gated): serves /auth/nginx, /start, /callback
    location /outpost.goauthentik.io {
        proxy_pass {{.AuthProvider.ProviderURL}}/outpost.goauthentik.io;
        proxy_set_header Host $host;
        proxy_set_header X-Original-URL $scheme://$http_host$request_uri;
        auth_request_set $auth_cookie $upstream_http_set_cookie;
        add_header Set-Cookie $auth_cookie;
        proxy_pass_request_body off;
        proxy_set_header Content-Length "";
        modsecurity off;
    }
{{- else}}
    location = /internal/forwardauth/verify {
        internal;
        proxy_pass {{.AuthProvider.ProviderURL}}{{.AuthProvider.Config.VerifyPath}};
{{- range .AuthProvider.Config.RequestHeaders}}
        proxy_set_header {{.Name}} {{.Value}};
{{- end}}
        proxy_set_header Content-Length "";
        proxy_pass_request_body off;
        proxy_connect_timeout 5s;
        proxy_read_timeout {{.AuthProvider.TimeoutMs}}ms;
        modsecurity off;
    }
{{- range .AuthProvider.Config.PublicPaths}}
    location {{.}} {
        proxy_pass {{$.AuthProvider.ProviderURL}}{{.}};
        proxy_set_header Host $host;
        modsecurity off;
    }
{{- end}}
{{- end}}
{{ end -}}
{{- define "_auth_gate" -}}
        # --- ForwardAuth ({{.AuthProvider.Type}}) gate ---
{{- if eq .AuthProvider.Type "authelia"}}
        auth_request /internal/forwardauth/verify;
        auth_request_set $fa_user $upstream_http_remote_user;
        auth_request_set $fa_groups $upstream_http_remote_groups;
        auth_request_set $fa_name $upstream_http_remote_name;
        auth_request_set $fa_email $upstream_http_remote_email;
        proxy_set_header Remote-User $fa_user;
        proxy_set_header Remote-Groups $fa_groups;
        proxy_set_header Remote-Name $fa_name;
        proxy_set_header Remote-Email $fa_email;
        auth_request_set $fa_redirect $upstream_http_location;
        error_page 401 =302 $fa_redirect;
{{- else if eq .AuthProvider.Type "authentik"}}
        auth_request /outpost.goauthentik.io/auth/nginx;
        error_page 401 = @forwardauth_signin;
        auth_request_set $auth_cookie $upstream_http_set_cookie;
        add_header Set-Cookie $auth_cookie;
        auth_request_set $fa_username $upstream_http_x_authentik_username;
        auth_request_set $fa_groups $upstream_http_x_authentik_groups;
        auth_request_set $fa_email $upstream_http_x_authentik_email;
        auth_request_set $fa_name $upstream_http_x_authentik_name;
        auth_request_set $fa_uid $upstream_http_x_authentik_uid;
        auth_request_set $fa_entitlements $upstream_http_x_authentik_entitlements;
        proxy_set_header X-authentik-username $fa_username;
        proxy_set_header X-authentik-groups $fa_groups;
        proxy_set_header X-authentik-email $fa_email;
        proxy_set_header X-authentik-name $fa_name;
        proxy_set_header X-authentik-uid $fa_uid;
        proxy_set_header X-authentik-entitlements $fa_entitlements;
{{- else}}
        auth_request /internal/forwardauth/verify;
{{- range .AuthProvider.Config.ResponseHeaders}}
        auth_request_set ${{.Var}} $upstream_http_{{.Upstream}};
        proxy_set_header {{.Forward}} ${{.Var}};
{{- end}}
{{- if .AuthProvider.Config.CookiePassthrough}}
        auth_request_set $auth_cookie $upstream_http_set_cookie;
        add_header Set-Cookie $auth_cookie;
{{- end}}
{{- if eq .AuthProvider.Config.SigninMode "location_header"}}
        auth_request_set $fa_redirect $upstream_http_location;
        error_page 401 =302 $fa_redirect;
{{- else}}
        error_page 401 = @forwardauth_signin;
{{- end}}
{{- end}}
{{ end -}}
{{- define "_auth_signin_location" -}}
{{- if eq .AuthProvider.Type "authentik"}}
    location @forwardauth_signin {
        internal;
        add_header Set-Cookie $auth_cookie;
        return 302 /outpost.goauthentik.io/start?rd=$scheme://$http_host$request_uri;
    }
{{- else if and (eq .AuthProvider.Type "custom") (ne .AuthProvider.Config.SigninMode "location_header")}}
    location @forwardauth_signin {
        internal;
{{- if .AuthProvider.Config.CookiePassthrough}}
        add_header Set-Cookie $auth_cookie;
{{- end}}
        return 302 {{.AuthProvider.Config.SigninRedirect}};
    }
{{- end}}
{{ end -}}
{{- define "_auth_bypass_locations" -}}
{{- range .Host.AuthBypassPaths}}
    # ForwardAuth bypass: {{.}}
    location {{.}} {
        auth_request off;
        {{if and $.Upstream $.Upstream.Servers}}proxy_pass {{upstreamScheme $.Upstream}}://{{$.Upstream.Name}};{{if eq (upstreamScheme $.Upstream) "https"}}
        proxy_ssl_server_name on;
        proxy_ssl_name $host;
        proxy_ssl_verify off;{{end}}{{else}}proxy_pass {{$.Host.ForwardScheme}}://npg_direct_{{sanitizeID $.Host.ID}};
        proxy_redirect {{$.Host.ForwardScheme}}://{{$.Host.ForwardHost}}:{{$.Host.ForwardPort}}/ /;{{end}}
        include /etc/nginx/includes/proxy_params.conf;
{{- if $.Host.AllowWebsocketUpgrade}}
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
{{- end}}
    }
{{- end}}
{{ end -}}
