{{if .BannedIPs}}
# Banned IPs geo mapping for {{join .Host.DomainNames ", "}}
# Values: 1 = manual ban, 0 = trusted (override)
# Filter subscription IPs are matched by the shared $filter_sub_ip geo
# (conf.d/filter_sub_ips_geo.conf) - one radix tree for all hosts.
geo $banned_ip_{{sanitizeID .Host.ID}} {
    default 0;
{{range .BannedIPs}}
    {{.IPAddress}} 1; # {{.Reason}}
{{end}}
{{range .GlobalTrustedIPs}}
    {{.}} 0; # global trusted IP (override)
{{end}}
}
{{end}}

{{if .GlobalTrustedIPs}}
# Global trusted IPs geo mapping (bypass all security)
geo $trusted_ip_{{sanitizeID .Host.ID}} {
    default 0;
{{range .GlobalTrustedIPs}}
    {{.}} 1;
{{end}}
}
{{end}}

{{if .BlockedCloudIPRanges}}
# Blocked Cloud Provider IPs geo mapping for {{join .Host.DomainNames ", "}}
# Using include file for efficiency ({{len .BlockedCloudIPRanges}} ranges)
geo $blocked_cloud_{{sanitizeID .Host.ID}} {
    default 0;
    include /etc/nginx/conf.d/includes/cloud_ips_{{.Host.ID}}.conf;
}
{{end}}

